{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "An email address collected for the discount code.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the lead."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the lead was created."
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": {
        "$ref": "#/entities/Lead"
      },
      "description": "Collection of collected email leads."
    }
  }
}
